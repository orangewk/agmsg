---
import "../styles/global.css";
import fs from "node:fs";
import path from "node:path";
import { fileURLToPath } from "node:url";
import { defaultLang, languages, localizedPath, useTranslations } from "../i18n/utils.js";

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// --- Agent Types gallery: data-driven from scripts/drivers/types/*/type.conf ---
const typesDir = fileURLToPath(new URL("../../../scripts/drivers/types", import.meta.url));

function parseConf(file) {
  const out = {};
  for (const line of fs.readFileSync(file, "utf8").split("\n")) {
    const m = line.match(/^([a-z_]+)=(.*)$/);
    if (m) out[m[1]] = m[2].trim();
  }
  return out;
}

// Proto-only display metadata (type.conf has no name/blurb yet). The blurb
// here is the English fallback; translated dictionaries key their own
// blurbs by the same agent name under agentTypes.blurbs.
const META = {
  "claude-code": { label: "Claude Code", logo: "/logos/claude.svg", blurb: "Anthropic's agentic coding CLI.", mono: true },
  codex:         { label: "Codex",        logo: "/logos/codex.svg", blurb: "OpenAI's terminal coding agent.", mono: true },
  gemini:        { label: "Gemini CLI",   logo: "/logos/gemini.svg", blurb: "Google's CLI coding agent." },
  copilot:       { label: "Copilot CLI",  logo: "/logos/copilot.svg", blurb: "GitHub Copilot in the shell." },
  cursor:        { label: "Cursor Agent", logo: null, blurb: "Cursor's headless CLI agent." },
  opencode:      { label: "OpenCode",     logo: "/logos/opencode.svg", blurb: "Open-source coding agent.", mono: true },
  "grok-build":  { label: "Grok Build",   logo: "/logos/grok.svg", blurb: "xAI's build/coding agent.", mono: true },
  hermes:        { label: "Hermes",       logo: "/logos/hermes.png", blurb: "Lightweight relay agent." },
  antigravity:   { label: "Antigravity",  logo: "/logos/antigravity.png", blurb: "Agentic coding environment." },
};

const agents = fs.readdirSync(typesDir)
  .filter((d) => fs.existsSync(path.join(typesDir, d, "type.conf")))
  .map((name) => {
    const c = parseConf(path.join(typesDir, name, "type.conf"));
    const meta = META[name] || { label: name, logo: null, blurb: "" };
    const modes = (c.delivery_modes || "").split(/\s+/).filter((m) => m && m !== "off");
    const status = name === "codex" ? "bridge" : c.monitor === "yes" ? "native" : "rule-file";
    return {
      name,
      label: meta.label,
      logo: meta.logo,
      mono: meta.mono || false,
      blurb: t.agentTypes.blurbs[name] || meta.blurb,
      spawnable: c.spawnable === "yes",
      monitor: c.monitor === "yes",
      modes,
      status,
    };
  })
  .sort((a, b) => a.label.localeCompare(b.label));

// --- Showcase gallery: real public GitHub repos built on agmsg. Star counts are
// approximate (build-time snapshot); a future build can fetch them via the API. ---
const showcase = [
  { owner: "lucianlamp", repo: "agkanban", desc: t.showcase.desc.agkanban, lang: "Shell", langColor: "#89e051", stars: "9", img: "/showcase/agkanban.png" },
  { owner: "shinshin86", repo: "agmsg-office", desc: t.showcase.desc["agmsg-office"], lang: "TypeScript", langColor: "#3178c6", stars: "5", img: "/showcase/agmsg-office.png" },
  { owner: "utenadev", repo: "agmsg-viewer", desc: t.showcase.desc["agmsg-viewer"], lang: "Go", langColor: "#00add8", stars: "1", img: "/showcase/agmsg-viewer.png" },
];

// GitHub mark (simple-icons), inlined so the proto needs no icon dependency.
const githubPath = "M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12";

const statusColor = {
  native: "text-accent border-accent/40 bg-accent/10",
  bridge: "text-amber border-amber/40 bg-amber/10",
  "rule-file": "text-muted border-border bg-white/5",
};

// GitHub star count: baked at build time as the fallback, refreshed client-side
// on load (see the inline script). Format e.g. 900 -> "900", 1200 -> "1.2k".
function fmtStars(n) {
  return n >= 1000 ? (n / 1000).toFixed(1).replace(/\.0$/, "") + "k" : String(n);
}
let starFallback = "900";
try {
  const r = await fetch("https://api.github.com/repos/fujibee/agmsg");
  if (r.ok) {
    const j = await r.json();
    if (typeof j.stargazers_count === "number") starFallback = fmtStars(j.stargazers_count);
  }
} catch (_) { /* offline build: keep the static fallback */ }

// Page metadata (title / description / social card) — localized per lang.
const siteUrl = "https://agmsg.cc";
const pageTitle = t.meta.title;
const pageDesc = t.meta.description;
const ogImage = `${siteUrl}/og.png`;
const canonicalUrl = `${siteUrl}${localizedPath(lang, "/")}`;
const localeCodes = Object.keys(languages);
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc} />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="theme-color" content="#0d1117" />
  <link rel="icon" type="image/png" sizes="32x32" href="/brand/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/brand/favicon-16.png" />
  <link rel="apple-touch-icon" href="/brand/apple-touch-icon-180.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- hreflang alternates: one per supported locale, plus x-default (= English). -->
  {localeCodes.map((code) => (
    <link rel="alternate" hreflang={code} href={`${siteUrl}${localizedPath(code, "/")}`} />
  ))}
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}${localizedPath(defaultLang, "/")}`} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="agmsg" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:alt" content={t.meta.ogImageAlt} />
  <meta property="og:locale" content={lang.replace("-", "_")} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDesc} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen antialiased">
  <!-- Nav -->
  <header class="sticky top-0 z-30 border-b border-border/70 bg-bg/80 backdrop-blur">
    <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href={localizedPath(lang, "/")} class="flex items-center">
        <img src="/brand/logo-full-dark.png" alt="agmsg" class="h-8 w-auto" />
      </a>
      <div class="hidden items-center gap-7 text-sm text-muted md:flex">
        <a class="hover:text-fg" href="#how">{t.nav.howItWorks}</a>
        <a class="hover:text-fg" href="#agents">{t.nav.agentTypes}</a>
        <a class="hover:text-fg" href="#desktop">{t.nav.desktopApp}</a>
        <a class="hover:text-fg" href="#showcase">{t.nav.showcase}</a>
        <a class="hover:text-fg" href="https://github.com/fujibee/agmsg">{t.nav.docs}</a>
      </div>
      <a href="https://github.com/fujibee/agmsg" class="flex items-center gap-2 rounded-lg border border-border bg-surface px-3.5 py-1.5 text-sm font-medium hover:border-accent/50">
        <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true"><path d={githubPath}></path></svg>
        <span>{t.nav.github}</span>
        <span class="ml-1 border-l border-border pl-2 font-mono text-xs text-muted">★ <span class="js-stars">{starFallback}</span></span>
      </a>
    </nav>
  </header>

  <!-- 1. Hero -->
  <section class="dot-grid relative overflow-hidden border-b border-border/60">
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-bg"></div>
    <div class="relative mx-auto max-w-6xl px-6 py-24 md:py-28">
      <div class="grid items-center gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
        <!-- LEFT: copy -->
        <div class="fade-up min-w-0">
          <a href="https://www.producthunt.com/products/agmsg" target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full border border-amber/40 bg-amber/10 px-3 py-1 text-xs font-medium text-amber transition hover:bg-amber/20">
            {t.hero.badge}
          </a>
          <h1 class="mt-6 text-[2.4rem] font-extrabold leading-[1.08] tracking-tight md:text-[2.9rem]">
            {t.hero.titleLine1} <br class="hidden lg:block" /><span class="text-accent">{t.hero.titleHighlight}</span> <br class="hidden lg:block" />{t.hero.titleLine2}
          </h1>
          <p class="mt-6 max-w-xl text-lg text-muted">
            {t.hero.subtitle}
          </p>

          <div class="mt-8 max-w-md">
            <div class="flex gap-1 text-sm font-medium">
              <button type="button" class="install-tab active rounded-t-lg border border-b-0 border-border bg-surface px-4 py-2 text-fg" data-tab="cli">{t.hero.installTabCli}</button>
              <button type="button" class="install-tab rounded-t-lg border border-b-0 border-transparent px-4 py-2 text-muted transition hover:text-fg" data-tab="mac">{t.hero.installTabMac}</button>
              <button type="button" class="install-tab rounded-t-lg border border-b-0 border-transparent px-4 py-2 text-muted transition hover:text-fg" data-tab="win">{t.hero.installTabWin}</button>
            </div>
            <div class="rounded-b-xl rounded-tr-xl border border-border bg-surface px-4 py-3 font-mono text-sm">
              <div class="install-panel flex items-center gap-2" data-panel="cli">
                <span class="select-none text-muted">$</span>
                <code class="text-fg">npx agmsg</code>
                <button type="button" class="copy-btn ml-auto shrink-0 rounded-md p-1.5 text-muted transition hover:bg-white/10 hover:text-fg" data-copy="npx agmsg" aria-label={t.hero.copyInstallAria}>
                  <svg class="copy-icon h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                  <svg class="check-icon hidden h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                </button>
              </div>
              <div class="install-panel flex items-center gap-2" data-panel="mac" style="display: none;">
                <span class="select-none text-muted">$</span>
                <code class="text-fg">brew tap fujibee/agmsg &amp;&amp; brew trust fujibee/agmsg &amp;&amp; brew install --cask agmsg</code>
                <button type="button" class="copy-btn ml-auto shrink-0 rounded-md p-1.5 text-muted transition hover:bg-white/10 hover:text-fg" data-copy="brew tap fujibee/agmsg && brew trust fujibee/agmsg && brew install --cask agmsg" aria-label={t.hero.copyInstallAria}>
                  <svg class="copy-icon h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                  <svg class="check-icon hidden h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                </button>
              </div>
              <div class="install-panel flex items-center justify-between" data-panel="win" style="display: none;">
                <span class="text-muted">{t.hero.winDownloadLabel}</span>
                <a href="https://github.com/fujibee/agmsg/releases/tag/app-latest" class="shrink-0 text-accent hover:underline">{t.hero.winDownloadLink}</a>
              </div>
            </div>
          </div>

          <div class="mt-8 flex flex-wrap items-center gap-3">
            <a href="#agents" class="cta rounded-xl bg-accent px-6 py-3 font-semibold text-bg">{t.hero.ctaGetStarted}</a>
            <a href="https://github.com/fujibee/agmsg" class="cta flex items-center gap-2.5 rounded-xl border border-border bg-surface px-6 py-3 font-medium text-fg hover:border-accent/50">
              <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true"><path d={githubPath}></path></svg>
              <span>{t.hero.ctaStarOnGithub}</span>
              <span class="js-stars font-mono text-sm text-muted">{starFallback}</span>
            </a>
          </div>
        </div>

        <!-- RIGHT: demo -->
        <div class="fade-up min-w-0 overflow-hidden rounded-2xl border border-border bg-surface shadow-2xl lg:max-w-[30rem] lg:justify-self-end">
          <img src="/agmsg-demo.gif" alt="agmsg demo" class="w-full" />
        </div>
      </div>

      <!-- supported agents strip (full width, left-aligned) -->
      <div class="fade-up mt-16">
        <p class="text-xs uppercase tracking-widest text-muted">{t.hero.worksAcross}</p>
        <div class="mt-4 flex flex-wrap items-center gap-x-7 gap-y-4 opacity-90">
          {agents.filter((a) => a.logo).map((a) => (
            <img src={a.logo} alt={a.label} title={a.label} class:list={["h-7 w-auto transition", a.mono && "invert"]} />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 2. How it works — before / after (above Agent types: explain value first) -->
  <section id="how" class="border-b border-border/60">
    <div class="mx-auto max-w-6xl px-6 py-20 md:py-24">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-bold tracking-tight md:text-4xl">{t.howItWorks.heading}</h2>
        <p class="mt-3 text-muted">{t.howItWorks.subtitle}</p>
      </div>

      <div class="mt-12 grid gap-5 lg:grid-cols-2">
        <!-- BEFORE -->
        <div class="min-w-0 rounded-2xl border border-border bg-surface/40 p-6 md:p-8">
          <span class="inline-flex items-center gap-2 rounded-full border border-amber/40 bg-amber/10 px-3 py-1 text-xs font-medium text-amber">{t.howItWorks.before.badge}</span>
          <h3 class="mt-4 text-lg font-semibold">{t.howItWorks.before.heading}</h3>
          <div class="mt-6 flex items-center justify-between gap-2">
            <div class="flex flex-col items-center gap-2">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl border border-border bg-bg p-2"><img src="/logos/claude.svg" alt="Claude Code" class="h-7 w-7 invert" /></div>
              <span class="text-xs text-muted">Claude Code</span>
            </div>
            <svg class="h-5 min-w-0 flex-1 text-amber/60" viewBox="0 0 100 20" fill="none" preserveAspectRatio="none"><path d="M2 10h96" stroke="currentColor" stroke-width="2" stroke-dasharray="5 5" stroke-linecap="round"/></svg>
            <div class="flex flex-col items-center gap-2">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl border border-amber/40 bg-amber/10 text-amber">
                <svg viewBox="0 0 24 24" class="h-6 w-6 fill-current" aria-hidden="true"><path d="M12 12a5 5 0 100-10 5 5 0 000 10zm0 2c-5 0-9 2.5-9 6v2h18v-2c0-3.5-4-6-9-6z"/></svg>
              </div>
              <span class="text-xs text-amber">{t.howItWorks.before.youLabel}</span>
            </div>
            <svg class="h-5 min-w-0 flex-1 text-amber/60" viewBox="0 0 100 20" fill="none" preserveAspectRatio="none"><path d="M2 10h96" stroke="currentColor" stroke-width="2" stroke-dasharray="5 5" stroke-linecap="round"/></svg>
            <div class="flex flex-col items-center gap-2">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl border border-border bg-bg p-2"><img src="/logos/codex.svg" alt="Codex" class="h-7 w-7 invert" /></div>
              <span class="text-xs text-muted">Codex</span>
            </div>
          </div>
          <p class="mt-6 text-sm text-muted">{t.howItWorks.before.body}</p>
        </div>

        <!-- AFTER -->
        <div class="card min-w-0 rounded-2xl border border-accent/40 bg-accent/5 p-6 md:p-8">
          <span class="inline-flex items-center gap-2 rounded-full border border-accent/40 bg-accent/15 px-3 py-1 text-xs font-medium text-accent">{t.howItWorks.after.badge}</span>
          <h3 class="mt-4 text-lg font-semibold">{t.howItWorks.after.heading}</h3>
          <div class="mt-6 flex items-center justify-between gap-2">
            <div class="flex flex-col items-center gap-2">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl border border-border bg-bg p-2"><img src="/logos/claude.svg" alt="Claude Code" class="h-7 w-7 invert" /></div>
              <span class="text-xs text-muted">Claude Code</span>
            </div>
            <svg class="h-5 min-w-0 flex-1 text-accent" viewBox="0 0 100 20" fill="none" preserveAspectRatio="none"><path d="M2 10h90m0 0l-7-6m7 6l-7 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <div class="flex flex-col items-center gap-2">
              <div class="flex h-12 items-center justify-center rounded-xl border border-accent/50 bg-bg px-3 font-mono text-xs text-accent">agmsg · sqlite</div>
              <span class="text-xs text-accent">{t.howItWorks.after.sharedLogLabel}</span>
            </div>
            <svg class="h-5 min-w-0 flex-1 text-accent" viewBox="0 0 100 20" fill="none" preserveAspectRatio="none"><path d="M2 10h90m0 0l-7-6m7 6l-7 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <div class="flex flex-col items-center gap-2">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl border border-border bg-bg p-2"><img src="/logos/codex.svg" alt="Codex" class="h-7 w-7 invert" /></div>
              <span class="text-xs text-muted">Codex</span>
            </div>
          </div>
          <div class="mt-6 flex flex-wrap gap-2">
            <span class="rounded-md border border-accent/30 bg-accent/10 px-2.5 py-1 font-mono text-xs text-accent">{t.howItWorks.after.tagNoDaemon}</span>
            <span class="rounded-md border border-accent/30 bg-accent/10 px-2.5 py-1 font-mono text-xs text-accent">{t.howItWorks.after.tagNoNetwork}</span>
            <span class="rounded-md border border-accent/30 bg-accent/10 px-2.5 py-1 font-mono text-xs text-accent">{t.howItWorks.after.tagRealTime}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Agent Types gallery (Bento) -->
  <section id="agents" class="mx-auto max-w-6xl px-6 py-20 md:py-24">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">{t.agentTypes.heading}</h2>
      <p class="mt-3 text-muted">{t.agentTypes.subtitle}</p>
    </div>
    <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {agents.map((a) => (
        <div class="card flex flex-col rounded-2xl border border-border bg-surface p-6">
          <div class="flex items-center gap-3">
            {a.logo
              ? <img src={a.logo} alt={a.label} class:list={["h-9 w-9 object-contain", a.mono && "invert"]} />
              : <span class="flex h-9 w-9 items-center justify-center rounded-lg border border-border bg-bg font-mono text-sm text-muted">{a.label.slice(0,2)}</span>}
            <div>
              <h3 class="font-semibold leading-tight">{a.label}</h3>
              <code class="text-xs text-muted">{a.name}</code>
            </div>
            <span class={`ml-auto rounded-md border px-2 py-0.5 text-[11px] font-medium ${statusColor[a.status]}`}>{t.agentTypes.status[a.status]}</span>
          </div>
          <p class="mt-4 text-sm text-muted">{a.blurb}</p>
          <div class="mt-5 flex flex-wrap gap-1.5">
            {a.spawnable && <span class="rounded-md border border-border bg-bg px-2 py-0.5 font-mono text-[11px] text-fg">{t.agentTypes.badgeSpawnable}</span>}
            {a.monitor && <span class="rounded-md border border-accent/30 bg-accent/10 px-2 py-0.5 font-mono text-[11px] text-accent">{t.agentTypes.badgeMonitor}</span>}
            {a.modes.filter((m) => !(m === "monitor" && a.monitor)).map((m) => (
              <span class="rounded-md border border-border bg-bg px-2 py-0.5 font-mono text-[11px] text-muted">{m}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 3b. Desktop app -->
  <section id="desktop" class="border-y border-border/60 bg-surface/30">
    <div class="mx-auto max-w-6xl px-6 py-20 md:py-24">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-bold tracking-tight md:text-4xl">{t.desktop.heading}</h2>
        <p class="mt-3 text-muted">{t.desktop.body}</p>
      </div>
      <!-- Still from the walkthrough recording; the demo video replaces it later. -->
      <img
        src="/demo/app-first-look.png"
        alt={t.desktop.heading}
        class="mt-10 w-full rounded-2xl border border-border"
        loading="lazy"
        width="1600"
        height="998"
      />
    </div>
  </section>

  <!-- 3. Showcase gallery (Bento) -->
  <section id="showcase" class="border-y border-border/60 bg-surface/30">
    <div class="mx-auto max-w-6xl px-6 py-20 md:py-24">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-bold tracking-tight md:text-4xl">{t.showcase.heading}</h2>
        <p class="mt-3 text-muted">{t.showcase.subtitle}</p>
      </div>
      <div class="mt-10 grid grid-cols-1 gap-4 md:grid-cols-3">
        {showcase.map((s) => (
          <a href={`https://github.com/${s.owner}/${s.repo}`} class="card group flex flex-col overflow-hidden rounded-2xl border border-border bg-surface">
            <div class="aspect-[16/9] overflow-hidden border-b border-border bg-bg">
              <img src={s.img} alt={s.repo} loading="lazy" class="h-full w-full object-cover opacity-90 transition group-hover:opacity-100" />
            </div>
            <div class="flex flex-1 flex-col p-6">
              <div class="flex items-center gap-2.5">
                <svg viewBox="0 0 24 24" class="h-5 w-5 fill-muted transition group-hover:fill-accent" aria-hidden="true"><path d={githubPath}></path></svg>
                <span class="font-mono text-sm leading-none"><span class="text-muted">{s.owner}/</span><span class="font-semibold text-fg">{s.repo}</span></span>
                <svg viewBox="0 0 24 24" class="ml-auto h-4 w-4 fill-none stroke-muted stroke-2 opacity-0 transition group-hover:opacity-100" aria-hidden="true"><path d="M7 17L17 7M9 7h8v8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <p class="mt-4 flex-1 text-sm text-muted">{s.desc}</p>
              <div class="mt-5 flex items-center gap-4 text-xs text-muted">
                <span class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full" style={`background:${s.langColor}`}></span>{s.lang}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <footer class="border-t border-border/60">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-3 px-6 py-10 text-sm text-muted md:flex-row">
      <span>{t.footer.tagline}</span>
      <div class="flex items-center gap-4">
        <span class="font-mono">agmsg.cc</span>
        <!-- Language switcher: an unobtrusive fallback for browser auto-detect,
             not a primary nav element — kept small and out of the header. -->
        <details class="lang-switcher relative">
          <summary class="flex cursor-pointer list-none items-center gap-1 rounded-md border border-border px-2 py-1 text-xs text-muted hover:border-accent/50 hover:text-fg">
            <span aria-hidden="true">🌐</span>
            <span>{languages[lang]}</span>
          </summary>
          <ul class="absolute bottom-full right-0 mb-2 w-40 rounded-lg border border-border bg-surface p-1 text-left shadow-xl">
            {localeCodes.map((code) => (
              <li>
                <a
                  href={localizedPath(code, "/")}
                  data-lang={code}
                  class:list={["lang-option block rounded-md px-2.5 py-1.5 text-xs hover:bg-white/10", code === lang ? "text-accent" : "text-muted"]}
                >
                  {languages[code]}
                </a>
              </li>
            ))}
          </ul>
        </details>
      </div>
    </div>
  </footer>

  <!-- Live GitHub star count (refreshes the build-time fallback). -->
  <script is:inline>
    fetch("https://api.github.com/repos/fujibee/agmsg")
      .then((r) => (r.ok ? r.json() : null))
      .then((d) => {
        if (!d || typeof d.stargazers_count !== "number") return;
        const n = d.stargazers_count;
        const s = n >= 1000 ? (n / 1000).toFixed(1).replace(/\.0$/, "") + "k" : String(n);
        document.querySelectorAll(".js-stars").forEach((el) => { el.textContent = s; });
      })
      .catch(() => {});

    // Copy the install command(s).
    document.querySelectorAll(".copy-btn").forEach((copyBtn) => {
      copyBtn.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(copyBtn.dataset.copy);
          const c = copyBtn.querySelector(".copy-icon"), k = copyBtn.querySelector(".check-icon");
          c.classList.add("hidden"); k.classList.remove("hidden");
          setTimeout(() => { k.classList.add("hidden"); c.classList.remove("hidden"); }, 1500);
        } catch (_) {}
      });
    });

    // Hero install box: CLI / macOS / Windows tabs.
    const installTabs = document.querySelectorAll(".install-tab");
    const installPanels = document.querySelectorAll(".install-panel");
    installTabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        installTabs.forEach((t) => {
          t.classList.remove("active", "border-border", "bg-surface", "text-fg");
          t.classList.add("border-transparent", "text-muted");
        });
        tab.classList.add("active", "border-border", "bg-surface", "text-fg");
        tab.classList.remove("border-transparent", "text-muted");
        installPanels.forEach((p) => { p.style.display = "none"; });
        document.querySelector(`.install-panel[data-panel="${tab.dataset.tab}"]`).style.display = "flex";
      });
    });

    // Remember an explicit language choice so future visits (and the
    // auto-detect script below) respect it instead of re-deriving from the
    // browser's Accept-Language every time.
    document.querySelectorAll(".lang-option").forEach((el) => {
      el.addEventListener("click", () => {
        try { localStorage.setItem("agmsg_lang", el.dataset.lang); } catch (_) {}
      });
    });
  </script>

  <!-- Browser-language auto-redirect: the primary language mechanism (the
       footer switcher above is just the manual override / escape hatch).
       Runs once per navigation; a stored explicit choice always wins over
       re-detecting navigator.language. -->
  <script is:inline define:vars={{ lang, supported: localeCodes }}>
    (function () {
      var KEY = "agmsg_lang";

      function pathFor(target) {
        var rest = location.pathname.replace(
          new RegExp("^/(" + supported.filter((l) => l !== "en").join("|") + ")(?=/|$)"),
          ""
        ) || "/";
        return target === "en" ? rest : "/" + target + rest;
      }

      function detect() {
        try {
          var stored = localStorage.getItem(KEY);
          if (stored && supported.indexOf(stored) !== -1) return stored;
        } catch (_) {}

        var candidates = navigator.languages && navigator.languages.length
          ? navigator.languages
          : [navigator.language || "en"];

        for (var i = 0; i < candidates.length; i++) {
          var raw = candidates[i];
          if (supported.indexOf(raw) !== -1) return raw;
          var base = raw.split("-")[0].toLowerCase();
          if (base === "zh") {
            return /tw|hant|hk|mo/i.test(raw) ? "zh-TW" : "zh-CN";
          }
          if (base === "pt") return "pt-BR";
          var match = supported.find(function (s) { return s.split("-")[0].toLowerCase() === base; });
          if (match) return match;
        }
        return "en";
      }

      var target = detect();
      if (target !== lang) {
        try { localStorage.setItem(KEY, target); } catch (_) {}
        location.replace(pathFor(target) + location.search + location.hash);
      }
    })();
  </script>
</body>
</html>
